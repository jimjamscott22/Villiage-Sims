{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VillageSim",
  "version": "0.1.0",
  "identifier": "com.villagesim.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VillageSim",
        "width": 1280,
        "height": 820,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": { "csp": null }
  },
  "bundle": { "active": false }
}
